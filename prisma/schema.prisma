generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         BigInt      @id @default(autoincrement())
  first_name String
  last_name  String
  username   String      @unique

  balance     Decimal  @db.Decimal(10, 3) @default(0)
  reserved_balance Decimal @db.Decimal(10, 3) @default(0)

  created_at DateTime    @default(now())

  userChats  UserChatActivity[]
  withdrawals WithdrawalRequest[]
}

model Chat {
  id         BigInt      @id @default(autoincrement())
  title      String
  budget     Decimal  @db.Decimal(10, 3) @default(0)
  food       Int    @default(10)
  materials  Int    @default(10)
  tools  Int    @default(10)
  level_workers Int @default(1)

  resource_id         BigInt @default(1)
  resource      Resource @relation(fields: [resource_id], references: [id])

  created_at DateTime    @default(now())

  user_chats  UserChatActivity[]  // связь с промежуточной таблицей
}

model Resource {
  id         BigInt      @id @default(autoincrement())
  name      String
  number      Decimal  @db.Decimal(10, 3)
  created_at DateTime    @default(now())

  chats      Chat[]
}

// Промежуточная таблица для связи многие ко многим с данными
model UserChatActivity {
  user_id    BigInt
  chat_id    BigInt
  total_messages    Int
  messages_per_hour Int
  joined_at DateTime     @default(now())

  user      User @relation(fields: [user_id], references: [id])
  chat      Chat @relation(fields: [chat_id], references: [id])

  @@id([user_id, chat_id]) // составной первичный ключ
}

model TonTransaction {
  id             String   @id @default(cuid())      // внутренний ID в базе
  tx_hash         String   @unique                  // хэш транзакции в блокчейне TON
  user_id       BigInt
  amount         Decimal  @db.Decimal(10, 3)                             
  amount_usdt    Decimal  @db.Decimal(10, 3)
  created_at      DateTime @default(now())            // запись в базу
}

model WithdrawalRequest {
  id          String   @id @default(cuid())
  user_id     BigInt
  amount      Decimal  @db.Decimal(10, 3)
  wallet      String
  status      WithdrawalStatus @default(PENDING)

  created_at   DateTime @default(now())
  processed_at DateTime?

  user      User @relation(fields: [user_id], references: [id])
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
}
